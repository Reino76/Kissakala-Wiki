---
import Layout from '../layouts/Layout.jsx';
const btnClass = "inline-flex items-center justify-center px-4 py-2 bg-white text-zinc-900 border border-zinc-200 text-[10px] font-black rounded-full uppercase tracking-widest dynamic-hover-accent transition-all w-full shadow-sm";
const logoBox = "w-12 h-12 rounded-xl mb-4 flex items-center justify-center border border-zinc-100 shadow-inner font-black text-xl bg-zinc-50";
---

<Layout title="Ohjelmistot ja Sovellukset" client:load>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {['Teams', 'Tuudo', 'Clockify', 'Discord', 'Frank', 'Canva'].map((app) => (
      <div class="bg-white p-6 rounded-3xl border-2 border-zinc-100 shadow-sm flex flex-col justify-between hover:border-zinc-300 transition-colors">
        <div>
          <div class={logoBox}>{app[0]}</div>
          <h3 class="text-xl font-black mb-2 uppercase tracking-tight">{app}</h3>
          <p class="text-zinc-600 text-sm mb-4 leading-relaxed opacity-70">Opintojen tueksi tarkoitettu sovellus.</p>
        </div>
        <a href="#" target="_blank" class={btnClass}>Avaa</a>
      </div>
    ))}
  </div>
</Layout>