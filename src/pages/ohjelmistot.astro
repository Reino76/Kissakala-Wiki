---
import Layout from '../layouts/Layout.jsx';

// Updated light button class
const btnClass = "inline-flex items-center justify-center px-4 py-2 bg-white text-zinc-900 border border-zinc-200 text-[10px] font-black rounded-full uppercase tracking-widest hover:bg-pink-500 hover:text-white hover:border-pink-500 transition-all w-full shadow-sm";

// Helper to create consistent logo placeholders
const logoBox = "w-12 h-12 rounded-xl mb-4 flex items-center justify-center border border-zinc-100 shadow-inner font-black text-xl";
---

<!DOCTYPE html>
<html lang="fi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Ohjelmistot ja Sovellukset - Kissakala Wiki</title>
  </head>
  <body>
    <Layout title="Ohjelmistot ja Sovellukset" client:load>
      <p class="text-lg text-zinc-600 mb-8 font-medium">
        Tärkeitä ohjelmistoja ja sovelluksia opintojen aikana.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div id="teams" class="bg-white p-6 rounded-3xl border-2 border-zinc-100 shadow-sm flex flex-col justify-between hover:border-pink-200 transition-colors group">
          <div>
            <div class={`${logoBox} bg-indigo-50 text-indigo-600`}>M</div>
            <h3 class="text-xl font-black mb-2 text-zinc-900 uppercase tracking-tight">Microsoft & Teams</h3> 
            <p class="text-zinc-600 text-sm leading-relaxed mb-4">
              Tuni-tunnuksilla saat lisenssin kaikkiin Microsoftin sovelluksiin.
            </p>
          </div>
          <a href="https://www.microsoft.com/fi-fi/microsoft-teams/group-chat-software" target="_blank" class={btnClass}>
            Avaa
          </a>
        </div>
        
        <div id="tuudo" class="bg-white p-6 rounded-3xl border-2 border-zinc-100 shadow-sm flex flex-col justify-between hover:border-pink-200 transition-colors group">
          <div>
            <div class={`${logoBox} bg-blue-50 text-blue-600`}>T</div>
            <h3 class="text-xl font-black mb-2 text-zinc-900 uppercase tracking-tight">Tuudo</h3> 
            <p class="text-zinc-600 text-sm leading-relaxed mb-4">
              Opiskelijakortti, lukujärjestykset ja opintosuoritukset.
            </p>
          </div>
          <a href="https://www.tuudo.fi/" target="_blank" class={btnClass}>
            Avaa
          </a>
        </div>

        <div id="clockify" class="bg-white p-6 rounded-3xl border-2 border-zinc-100 shadow-sm flex flex-col justify-between hover:border-pink-200 transition-colors group">
          <div>
            <div class={`${logoBox} bg-sky-50 text-sky-600`}>C</div>
            <h3 class="text-xl font-black mb-2 text-zinc-900 uppercase tracking-tight">Clockify</h3> 
            <p class="text-zinc-600 text-sm leading-relaxed mb-4">
              Sovellus ja nettisivu projektituntien merkitsemiseen.
            </p>
          </div>
          <a href="https://clockify.me/" target="_blank" class={btnClass}>
            Avaa
          </a>
        </div>

        <div class="bg-white p-6 rounded-3xl border-2 border-zinc-100 shadow-sm flex flex-col justify-between hover:border-pink-200 transition-colors group">
          <div>
            <div class={`${logoBox} bg-indigo-100 text-indigo-800`}>D</div>
            <h3 class="text-xl font-black mb-2 text-zinc-900 uppercase tracking-tight">Discord</h3> 
            <p class="text-zinc-600 text-sm leading-relaxed mb-4">
              VETO:n oma Discord-kanava yhteydenpitoon.
            </p>
          </div>
          <a href="https://discord.com/" target="_blank" class={btnClass}>
            Avaa
          </a>
        </div>

        <div class="bg-white p-6 rounded-3xl border-2 border-zinc-100 shadow-sm flex flex-col justify-between hover:border-pink-200 transition-colors group">
          <div>
            <div class={`${logoBox} bg-zinc-100 text-zinc-900`}>F</div>
            <h3 class="text-xl font-black mb-2 text-zinc-900 uppercase tracking-tight">Frank App</h3> 
            <p class="text-zinc-600 text-sm leading-relaxed mb-4">
              Opiskelijaedut ja alennuskoodit.
            </p>
          </div>
          <a href="https://www.frank.fi/lataa/" target="_blank" class={btnClass}>
            Avaa
          </a>
        </div>

        <div class="bg-white p-6 rounded-3xl border-2 border-zinc-100 shadow-sm flex flex-col justify-between hover:border-pink-200 transition-colors group">
          <div>
            <div class={`${logoBox} bg-teal-50 text-teal-600`}>C</div>
            <h3 class="text-xl font-black mb-2 text-zinc-900 uppercase tracking-tight">Canva</h3> 
            <p class="text-zinc-600 text-sm leading-relaxed mb-4">
              Helppokäyttöinen graafisen suunnittelun työkalu.
            </p>
          </div>
          <a href="https://www.canva.com/" target="_blank" class={btnClass}>
            Avaa
          </a>
        </div>
      </div>
    </Layout>
  </body>
</html>