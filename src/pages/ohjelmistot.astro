---
import MainLayout from '../layouts/MainLayout.astro';
import teamsLogo from '../images/teams.webp';
import tuudoLogo from '../images/tuudo.webp';
import clockifyLogo from '../images/clockifty.webp';
import discordLogo from '../images/discord.webp';
import frankLogo from '../images/frank.webp';
import canvaLogo from '../images/canva.webp';
import kideLogo from '../images/kide.webp';

const base = import.meta.env.BASE_URL;

// Standard button class for consistency
const btnClass = "inline-flex items-center justify-center px-4 py-2 bg-white text-zinc-900 border border-zinc-200 text-[10px] font-black rounded-full uppercase tracking-widest dynamic-hover-accent transition-all w-full shadow-sm";

// Helper for consistent logo placeholders
const logoBox = "w-12 h-12 rounded-xl mb-4 flex items-center justify-center border border-zinc-100 shadow-inner bg-zinc-50 overflow-hidden";

// Define the apps and their specific metadata
const apps = [
  { name: 'Teams', desc: 'Tärkein viestintäkanava projekteille ja opinnoille.', link: 'https://teams.microsoft.com', logo: teamsLogo },
  { name: 'Tuudo', desc: 'Opiskelijakortti, lukujärjestykset ja opintosuoritukset.', link: 'https://www.tuudo.fi/', logo: tuudoLogo },
  { name: 'Clockify', desc: 'Työkalu projektituntien seuraamiseen ja merkitsemiseen.', link: 'https://clockify.me/', logo: clockifyLogo },
  { name: 'Discord', desc: 'VETO:n oma kanava vapaamuotoiseen yhteydenpitoon.', link: 'https://discord.com/', logo: discordLogo },
  { name: 'Frank', desc: 'Opiskelija-alennukset ja digitaalinen opiskelijakortti.', link: 'https://www.frank.fi/', logo: frankLogo },
  { name: 'Canva', desc: 'Helppo työkalu graafiseen suunnitteluun ja esityksiin.', link: 'https://www.canva.com/', logo: canvaLogo },
  { name: 'Kide.app', desc: 'Tapahtumaliput, jäsenyydet + haalarit (wink)', link: 'https://kide.app/', logo: kideLogo }
];
---

<MainLayout title="Ohjelmistot ja Sovellukset">
  <p class="text-lg text-zinc-600 mb-8 font-medium">
    Tärkeitä ohjelmistoja ja sovelluksia opintojen aikana.
  </p>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {apps.map((app) => (
      <div id={app.name.toLowerCase().replace('.', '-')} class="bg-white p-6 rounded-3xl border-2 border-zinc-100 shadow-sm flex flex-col justify-between hover:border-zinc-300 transition-colors">
        <div>
          <div class={logoBox}>
            <img src={app.logo.src} alt={`${app.name} logo`} class="w-10 h-10 object-contain" />
          </div>
          <h3 class="text-xl font-black mb-2 uppercase tracking-tight text-zinc-900">{app.name}</h3>
          <p class="text-zinc-600 text-sm mb-4 leading-relaxed opacity-70">{app.desc}</p>
        </div>
        <a href={app.link} target="_blank" class={btnClass}>Avaa</a>
      </div>
    ))}
  </div>
</MainLayout>